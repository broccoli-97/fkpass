{
  "name": "fkpass",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "法考速记卷宗 — static design-system site + Cloudflare Pages feedback API. The published site has no build step; this package.json exists only for dev tooling (tests, linters, CI, deploy).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"src/tokens.css\" \"src/*.html\"",
    "lint:html": "html-validate \"src/*.html\"",
    "format:check": "prettier --check \"test/**/*.js\" \"*.config.js\" \"*.json\" \".github/**/*.yml\"",
    "format": "prettier --write \"test/**/*.js\" \"*.config.js\" \"*.json\" \".github/**/*.yml\"",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html && npm run format:check",
    "check": "npm run lint && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "html-validate": "^9.5.1",
    "postcss-html": "^1.7.0",
    "prettier": "^3.4.2",
    "stylelint": "^16.12.0",
    "stylelint-config-standard": "^36.0.1",
    "wrangler": "^3.99.0"
  }
}
